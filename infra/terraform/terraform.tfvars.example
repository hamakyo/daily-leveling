# 環境別の雛形は environments/ 配下を使ってください。
# これは任意の単一環境向けサンプルです。
account_id             = "replace_me"
worker_name            = "daily-leveling"
enable_workers_dev     = true
auth_rate_limits_namespace_id = null
zone_id                = "replace_me_if_using_zone_routing"
custom_domain_hostname = null
route_pattern          = null
