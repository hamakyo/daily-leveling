{
  "name": "daily-leveling",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n assets,worker -c blue,green \"pnpm dev:assets\" \"pnpm dev:worker\"",
    "dev:test": "concurrently -k -n assets,worker -c blue,green \"pnpm dev:assets\" \"pnpm dev:worker:test\"",
    "dev:staging": "concurrently -k -n assets,worker -c blue,green \"pnpm dev:assets\" \"pnpm dev:worker:staging\"",
    "dev:production": "concurrently -k -n assets,worker -c blue,green \"pnpm dev:assets\" \"pnpm dev:worker:production\"",
    "dev:assets": "vite build --watch",
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "dev:worker:test": "wrangler dev --env test",
    "dev:worker:staging": "wrangler dev --env staging",
    "dev:worker:production": "wrangler dev --env production",
    "build": "vite build",
    "check": "tsc --noEmit",
    "env:check": "node scripts/check-env.mjs --env local",
    "env:check:test": "node scripts/check-env.mjs --env test",
    "env:check:staging": "node scripts/check-env.mjs --env staging",
    "env:check:production": "node scripts/check-env.mjs --env production",
    "db:migrate": "node scripts/migrate.mjs --env local",
    "db:migrate:test": "node scripts/migrate.mjs --env test",
    "db:migrate:staging": "node scripts/migrate.mjs --env staging",
    "db:migrate:production": "node scripts/migrate.mjs --env production",
    "db:migrate:plan": "node scripts/migrate.mjs --env local --plan",
    "db:migrate:plan:test": "node scripts/migrate.mjs --env test --plan",
    "db:migrate:plan:staging": "node scripts/migrate.mjs --env staging --plan",
    "db:migrate:plan:production": "node scripts/migrate.mjs --env production --plan",
    "deploy:test": "pnpm run build && wrangler deploy --env test",
    "deploy:staging": "pnpm run build && wrangler deploy --env staging",
    "deploy:production": "pnpm run build && wrangler deploy --env production",
    "cf:whoami": "wrangler whoami",
    "cf:health:test": "curl -fsS https://daily-leveling-test.hamakyoh.workers.dev/healthz",
    "cf:health:staging": "curl -fsS https://daily-leveling-staging.hamakyoh.workers.dev/healthz",
    "cf:health:production": "curl -fsS https://daily-leveling.hamakyoh.workers.dev/healthz",
    "cf:deployments:test": "wrangler deployments list --env test --json",
    "cf:deployments:staging": "wrangler deployments list --env staging --json",
    "cf:deployments:production": "wrangler deployments list --env production --json",
    "cf:secrets:test": "wrangler secret list --env test",
    "cf:secrets:staging": "wrangler secret list --env staging",
    "cf:secrets:production": "wrangler secret list --env production",
    "deploy:dry-run:test": "pnpm run build && wrangler deploy --env test --dry-run",
    "deploy:dry-run:staging": "pnpm run build && wrangler deploy --env staging --dry-run",
    "deploy:dry-run:production": "pnpm run build && wrangler deploy --env production --dry-run",
    "infra:fmt": "terraform -chdir=infra/terraform fmt -check -diff",
    "infra:validate": "terraform -chdir=infra/terraform init -backend=false && terraform -chdir=infra/terraform validate",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:generate": "wrangler types",
    "verify": "pnpm run check && pnpm test && pnpm run build && pnpm run infra:fmt",
    "verify:full:test": "pnpm run verify && pnpm run infra:validate && pnpm run deploy:dry-run:test",
    "verify:full:staging": "pnpm run verify && pnpm run infra:validate && pnpm run deploy:dry-run:staging",
    "verify:full:production": "pnpm run verify && pnpm run infra:validate && pnpm run deploy:dry-run:production",
    "release:check:test": "pnpm run env:check:test && pnpm run db:migrate:plan:test && pnpm run verify:full:test",
    "release:check:staging": "pnpm run env:check:staging && pnpm run db:migrate:plan:staging && pnpm run verify:full:staging",
    "release:check:production": "pnpm run env:check:production && pnpm run db:migrate:plan:production && pnpm run verify:full:production"
  },
  "dependencies": {
    "hono": "^4.6.15",
    "postgres": "^3.4.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  }
}
