{
  "name": "daily-leveling",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n assets,worker -c blue,green \"pnpm dev:assets\" \"pnpm dev:worker\"",
    "dev:assets": "vite build --watch",
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "check": "tsc --noEmit",
    "deploy": "pnpm run build && wrangler deploy",
    "deploy:dry-run": "pnpm run build && wrangler deploy --dry-run",
    "infra:fmt": "terraform -chdir=infra/terraform fmt -check -diff",
    "infra:validate": "terraform -chdir=infra/terraform init -backend=false && terraform -chdir=infra/terraform validate",
    "test": "vitest run",
    "test:watch": "vitest",
    "types:generate": "wrangler types",
    "verify": "pnpm run check && pnpm test && pnpm run build && pnpm run infra:fmt",
    "verify:full": "pnpm run verify && pnpm run infra:validate && pnpm run deploy:dry-run"
  },
  "dependencies": {
    "hono": "^4.6.15",
    "postgres": "^3.4.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.0"
  }
}
